# Copy to terraform.tfvars and fill in your actual public IP.
# bash:       curl -s https://api.ipify.org
# powershell: (Invoke-WebRequest -Uri "https://api.ipify.org").Content

name_prefix   = "gskplat"
location      = "eastus2"
owner         = "gopalskhandale@gmail.com"
admin_ip_cidr = "1.2.3.4/32" # REPLACE with your real /32

# Defaults are usually fine; uncomment to override:
# vnet_cidr = "10.0.0.0/16"
# subnet_cidrs = {
#   aks  = "10.0.1.0/24"
#   apps = "10.0.2.0/24"
#   mgmt = "10.0.3.0/27"
# }
# log_analytics_retention_days = 30

# Iter 2 — ACR + AKS
# acr_sku            = "Basic"           # Basic | Standard | Premium
# aks_node_count     = 1                 # single-node lab default; B-series is blocked here, D2s_v3 is 2 vCPU/8 GB
# aks_vm_size        = "Standard_D2s_v3"
# kubernetes_version = null              # null = AKS picks latest stable
